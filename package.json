{
  "name": "@doko/react-native-yubikit",
  "version": "0.0.2",
  "description": "Yubikit bindings for React Native",
  "keywords": [
    "android",
    "ios",
    "react-native"
  ],
  "homepage": "https://github.com/Doko-Demo-Doa/react-native-yubikit#readme",
  "bugs": {
    "url": "https://github.com/Doko-Demo-Doa/react-native-yubikit/issues"
  },
  "license": "MIT",
  "author": "Quan Pham <doraemonfanclub@gmail.com> (https://github.com/Doko-Demo-Doah)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doko-Demo-Doa/react-native-yubikit.git"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-yubikit-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "example": "pnpm --filter react-native-yubikit-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "jest",
    "release": "release-it --only-version"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.2.0",
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-plugin": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/react": "^19.2.17",
    "commitlint": "^21.2.1",
    "del-cli": "^7.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "release-it": "^20.2.1",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "preset": "@react-native/jest-preset",
    "testEnvironmentOptions": {
      "customExportConditions": [
        "require",
        "react-native",
        "<%- project.sourceCondition -%>"
      ]
    }
  },
  "packageManager": "pnpm@11.10.0",
  "codegenConfig": {
    "name": "YubikitSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.yubikit"
    },
    "ios": {
      "modulesProvider": {
        "YubikitCore": "YubikitCore",
        "YubikitManagement": "YubikitManagement",
        "YubikitOath": "YubikitOath",
        "YubikitPiv": "YubikitPiv",
        "YubikitOpenPgp": "YubikitOpenPgp",
        "YubikitYubiOtp": "YubikitYubiOtp",
        "YubikitFido": "YubikitFido",
        "YubikitSupport": "YubikitSupport"
      }
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "oxlint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.63.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  }
}
