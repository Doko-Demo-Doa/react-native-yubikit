{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "react", "jest"],
  "jsPlugins": ["eslint-plugin-eslint-comments", "eslint-plugin-react-native"],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true,
    "es6": true
  },
  "globals": {
    "Map": "writable",
    "Promise": "writable",
    "Set": "writable",
    "__DEV__": "writable",
    "__dirname": "readonly",
    "__fbBatchedBridgeConfig": "readonly",
    "AbortController": "readonly",
    "Blob": "writable",
    "alert": "readonly",
    "cancelAnimationFrame": "readonly",
    "cancelIdleCallback": "readonly",
    "clearImmediate": "writable",
    "clearInterval": "readonly",
    "clearTimeout": "readonly",
    "console": "readonly",
    "document": "readonly",
    "ErrorUtils": "readonly",
    "Event": "readonly",
    "EventTarget": "readonly",
    "exports": "readonly",
    "fetch": "readonly",
    "File": "writable",
    "FileReader": "readonly",
    "FormData": "readonly",
    "global": "readonly",
    "Headers": "readonly",
    "module": "readonly",
    "navigator": "readonly",
    "process": "readonly",
    "requestAnimationFrame": "writable",
    "requestIdleCallback": "writable",
    "require": "readonly",
    "setImmediate": "writable",
    "setInterval": "readonly",
    "setTimeout": "readonly",
    "queueMicrotask": "writable",
    "URL": "readonly",
    "URLSearchParams": "readonly",
    "WebSocket": "writable",
    "window": "readonly",
    "XMLHttpRequest": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "lib/",
    "example/.expo/",
    "example/expo-env.d.ts",
    "example/src/uniwind-types.d.ts"
  ],
  "rules": {
    "no-cond-assign": "warn",
    "no-const-assign": "error",
    "no-control-regex": "warn",
    "no-debugger": "warn",
    "no-dupe-class-members": "error",
    "no-dupe-keys": "error",
    "no-ex-assign": "warn",
    "no-extra-boolean-cast": "warn",
    "no-func-assign": "warn",
    "no-invalid-regexp": "warn",
    "no-obj-calls": "warn",
    "no-regex-spaces": "warn",
    "no-sparse-arrays": "warn",
    "no-unreachable": "error",
    "use-isnan": "warn",
    "valid-typeof": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-alert": "warn",
    "no-caller": "warn",
    "no-div-regex": "warn",
    "no-eval": "error",
    "no-extend-native": "warn",
    "no-extra-bind": "warn",
    "no-fallthrough": "warn",
    "no-implied-eval": "warn",
    "no-labels": "warn",
    "no-iterator": "warn",
    "no-lone-blocks": "warn",
    "no-new": "warn",
    "no-new-func": "error",
    "no-new-wrappers": "warn",
    "no-proto": "warn",
    "no-return-assign": "warn",
    "no-script-url": "warn",
    "no-self-compare": "warn",
    "no-sequences": "warn",
    "no-useless-escape": "warn",
    "no-void": "warn",
    "no-with": "warn",
    "radix": "warn",
    "yoda": "warn",
    "no-delete-var": "warn",
    "no-global-assign": "error",
    "no-label-var": "warn",
    "no-shadow": "warn",
    "no-shadow-restricted-names": "warn",
    "no-unused-vars": [
      "warn",
      {
        "vars": "all",
        "args": "none",
        "ignoreRestSiblings": true
      }
    ],
    "eslint-comments/no-aggregating-enable": "warn",
    "eslint-comments/no-unlimited-disable": "warn",
    "eslint-comments/no-unused-disable": "warn",
    "eslint-comments/no-unused-enable": "warn",
    "no-array-constructor": "warn",
    "no-empty-character-class": "warn",
    "no-bitwise": "warn",
    "react/jsx-no-comment-textnodes": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-no-undef": "error",
    "react/no-did-mount-set-state": "warn",
    "react/no-did-update-set-state": "warn",
    "react/no-string-refs": "error",
    "react/no-unstable-nested-components": "warn",
    "react/self-closing-comp": "warn",
    "react-native/no-inline-styles": "warn",
    "jest/no-disabled-tests": "warn",
    "jest/no-focused-tests": "warn",
    "jest/no-identical-title": "warn",
    "jest/valid-expect": "warn",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "typescript/dot-notation": "warn"
  },
  "overrides": [
    {
      "files": ["**/*.js"],
      "rules": {
        "ft-flow/define-flow-type": "warn",
        "ft-flow/use-flow-type": "warn"
      },
      "jsPlugins": ["eslint-plugin-ft-flow"]
    },
    {
      "files": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
      "rules": {
        "@react-native/no-deep-imports": "warn"
      },
      "jsPlugins": ["@react-native/eslint-plugin"]
    },
    {
      "files": ["**/*.ts", "**/*.tsx"],
      "rules": {
        "no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "destructuredArrayIgnorePattern": "^_"
          }
        ]
      }
    },
    {
      "files": [
        "**/*.{spec,test}.{js,ts,tsx}",
        "**/__{mocks,tests}__/**/*.{js,ts,tsx}"
      ],
      "globals": {
        "fdescribe": "readonly",
        "pit": "readonly",
        "require": "readonly"
      },
      "env": {
        "jest": true
      }
    },
    {
      "files": [
        "**/*.{spec,test}.{js,ts,tsx}",
        "**/__{mocks,tests}__/**/*.{js,ts,tsx}"
      ],
      "env": {
        "jest": true
      }
    },
    {
      "files": [
        "**/*.{spec,test}.{js,ts,tsx}",
        "**/__{mocks,tests}__/**/*.{js,ts,tsx}"
      ],
      "rules": {
        "react-native/no-inline-styles": "off"
      },
      "jsPlugins": ["eslint-plugin-react-native"]
    }
  ]
}
