{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "quoteProps": "consistent",
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "ignorePatterns": [
    "node_modules/",
    "lib/",
    "example/.expo/",
    "example/expo-env.d.ts",
    "example/src/uniwind-types.d.ts"
  ]
}
